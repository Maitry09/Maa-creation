<footer class="footer">
    <div class="footer-3d-bg">
        <div class="footer-particles"></div>
    </div>
    <div class="container">
        <div class="footer-content">
            <div class="footer-section">
                <div class="footer-logo-3d">
                    <div class="logo-3d">
                        <i class="fas fa-camera-retro"></i>
                    </div>
                    <span><%= footer.logo %></span>
                </div>
                <p class="footer-description">
                    <%= footer.description %>
                </p>
                <div class="social-links-3d">
                    <% footer.socialLinks.forEach(link => { %>
                        <a target="_blank" href="<%= link.href %>" class="social-link-3d">
                            <i class="<%= link.icon %>"></i>
                        </a>
                    <% }) %>
                </div>
            </div>
            
            <div class="footer-section">
                <h4 class="footer-title">Services</h4>
                <ul class="footer-links">
                    <% footer.services.forEach(service => { %>
                        <li><a href="#"><%= service %></a></li>
                    <% }) %>
                </ul>
            </div>
            
            <div class="footer-section">
                <h4 class="footer-title">Quick Links</h4>
                <ul class="footer-links">
                    <% footer.quickLinks.forEach(link => { %>
                        <li><a href="<%= link.href %>"><%= link.name %></a></li>
                    <% }) %>
                </ul>
            </div>
            
            <div class="footer-section">
                <h4 class="footer-title">Contact Info</h4>
                <div class="footer-contact">
                    <% footer.contactInfo.forEach(info => { %>
                        <p><%= info %></p>
                    <% }) %>
                </div>
            </div>
        </div>
        
        <div class="footer-bottom">
            <p>&copy; 2024 Mahakali Studio. All rights reserved. | Crafted with passion for visual storytelling ❤️</p>
        </div>
    </div>
</footer>
